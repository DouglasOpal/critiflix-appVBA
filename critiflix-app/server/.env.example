# ---- Core ----
NODE_ENV=production
PORT=4000

# ---- Database (MongoDB Atlas free tier M0) ----
# Atlas → Connect → Drivers → copy the SRV string; add the DB name (…/critiflix).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/critiflix?retryWrites=true&w=majority

# ---- Auth secrets (use long random strings; Render can generate these) ----
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ---- First admin (created on first boot when the DB is empty) ----
ADMIN_EMAIL=admin@critiflix.app
ADMIN_NAME=CritiFlix Admin
ADMIN_PASSWORD=choose-a-strong-admin-password
SEED_ON_START=true

# ---- Twilio: SMS one-time codes + WhatsApp promotions ----
# Console → Account Info. Phone OTP sends real SMS only when these are set;
# otherwise the code is logged and returned for testing.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+1XXXXXXXXXX
# WhatsApp sender — Twilio sandbox number or your approved sender:
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- Paystack (payments) ----
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Set to your deployed URL once live:
PAYSTACK_CALLBACK_URL=https://critiflix-api.onrender.com/api/me/subscribe/callback
